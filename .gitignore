# ─────────────────────────────────────────────────────────────
# DocMind — .gitignore
# ─────────────────────────────────────────────────────────────


# ── Secrets ───────────────────────────────────────────────────
.env
.streamlit/secrets.toml


# ── Vector index & document metadata ─────────────────────────
# Generated at runtime — do not commit. Re-created on first run.
data/


# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg


# ── Virtual environments ──────────────────────────────────────
.venv/
venv/
env/
ENV/


# ── Testing & coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml


# ── IDEs ─────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store


# ── Uploads (local dev only) ──────────────────────────────────
uploads/
*.pdf
*.docx
*.csv
