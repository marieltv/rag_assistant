# ─────────────────────────────────────────────────────────────
# DocMind — Document Q&A RAG Assistant
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────


# ── LLM Provider (required for answers) ─────────────────────
OPENAI_API_KEY=sk-...


# ── Embeddings (local hybrid RAG — recommended) ───────────────
# Backend: "local" uses sentence-transformers (no API cost, better recall).
# Set to "openai" only if you prefer OpenAI embeddings (requires re-index).
RAG_EMBEDDING_BACKEND=local

# Local model (default matches jamwithai/beginner-local-rag-system):
RAG_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# OpenAI embedding model (only when RAG_EMBEDDING_BACKEND=openai):
# RAG_EMBEDDING_MODEL=text-embedding-3-small


# ── Chunking ─────────────────────────────────────────────────
# Word-based chunks (300 words, 100 overlap) — tuned for articles/PDFs.
RAG_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=100


# ── Retrieval ─────────────────────────────────────────────────
# Hybrid BM25 + vector search candidates before reranking.
RAG_TOP_K=10
RAG_RERANK_TOP_N=4

# Score threshold: 0 = disabled (recommended). Raise only for strict filtering.
RAG_SCORE_THRESHOLD=0.0


# ── LLM ───────────────────────────────────────────────────────
RAG_LLM_MODEL=gpt-4o-mini


# ── Storage ───────────────────────────────────────────────────
RAG_INDEX_DIR=data/faiss_index
RAG_METADATA_PATH=data/doc_metadata.json


# ── API Server (optional) ─────────────────────────────────────
RAG_API_URL=http://localhost:8000
